# Tryton ERP Docker Manager TRYDOCKCMD Versión 1.0.0
# Para que funcione TRYDOCKCMD se necesita Docker, PowerShell 5.1 o 7, además WSL 2 (S.O. Linux).
# Las pruebas se han realizado con Windows 10/11, y las últimas versiones de Tryton a partir de 7.X.X. y postgreSQL 12.X
# La programación en script .bat en Windows, el motivo es el S.O. por ser el más popular actualmente, siempre hay un portátil a mano con windows.
# Saldrá en breve la versión para linux con los script en .sh.
# Los datos e información del fichero .env se han testeado con la versión Tryton 7.X.X
# Es un desarrollo de http://www.telepieza.com (Sr. Mariano Vallespín) para la comunidad de Tryton con licencia (MIT License).
#
# Credenciales de Base de Datos. Información: Solo tiene que modificar las siguientes variables:
#   DB_PASSWORD y PASSWORD : El consejo es que tengan la misma clave, de esa forma no hay confusión. 
#   DB_PASSWORD: Clave para acceder a la base de datos Tryton de postgreSQL con el superusuario : postgres
#   PASSWORD: Clave para acceder con http://localhost:8000, solicita base de datos (tryton), usuario : admin (coge el dato de la variable DB_USER), y el password
#   EMAIL: Hay que cambiar el email, al recuperar la imagen y generar los contenedores, es la forma de contactar con el instalador, si hay problemas.
#   LANGUAGE: El idioma de los menús al arrancar el programa tcd.bat, por defecto es es-ES, puede ser en-US. Por ahora solo hay dos idiomas.
#   TRYTON_LANGUAGE: Por defecto Tryton tiene el lenguaje en (inglés), pero en la instalación se puede indicar que grabe los módulos de otro idioma, por defecto idioma: es.
# Observaciones:
#   Tryton ERP Docker Manager TRYDOCKCMD es para nuevas instalaciones, no actualiza de forma automática versionas anteriores con la versión actual (7.X.X). NO ES UN UPDATE.
#   El tiempo de instalación estimada sin Tryton ERP Docker Manager es de 6 a 8 horas, con TRYDOCKCMD es de tan solo 15 minutos, instalando de forma simultanea dos base de datos.
# Seguridad:
#   Tryton ERP Docker Manager TRYDOCKCMD. Interactua con los contenedores de tryton y postgreSQL de Docker, generá reports que graba en las carpetas asignadas dentro del proyecto
#   trydockcmd. Es un producto transparente y no es necesario ninguna instalación previa, no altera en nigún momento la configuración y los registros de windows.
# Importante:
#   Si desea realizar pruebas y pruebas, puede ir al IDE de Docker Desktop, borrar los contenedores, los volúmenes y por último las ímagenes (que empiecen por tryton), y volver a ejecutar tcd.bat,
#   volverá a descargar las últimas ímagenes (puede que sean versión superior a la que tenía instalada), y volver a trabajar con las nuevas imágenes. 
#   Si desea instalar una version en concreto, tiene que modificar el fichero compose.yml, cambiar en las líneas que tienen la palabra -latest por la versión deseada,
#   la oficial actualmente es la versión 7.4, ejemplo de una de las líneas image: tryton/tryton:${VERSION:7.4}, pero hay más líneas a modificar en el fichero compose.yml
#   La base de datos tryton-demo, el usuario es demo y el password es demo, no se configura por el fichero .env por ser una inyección del archivo .dump oficial a la base de datos tryton-demo.

DB_NAME=tryton
DB_USER=admin
DB_PASSWORD=clave1234
# Modifique el email, es importante en la instalacion, si hay problemas, es la forma de comunicarse.
EMAIL=youremail@yourdomain.com
# Configuración inicial de tryton (usuario admin, sin variable password: admin)
PASSWORD=clave1234
# Red interna
DB_HOSTNAME=postgres
DB_PORT=5432
TRYTOND_DATABASE_URI=postgresql://postgres:clave1234@tryton-postgres-1:5432/
# Menú TRYDOCKCMD: español (es-ES), inglés(en-US), por defecto es-ES
LANGUAGE=es-ES
# Incorpocar los modulos del idioma a Tryton, puede ser es,fr,de o blanco. Si es blanco no gestiona ningun lenguaje de forma automática al instalar el idioma y sus modulos.
TRYTON_LANGUAGE=es
# Ruta para localizar los ficheros .xml de cada uno de los módulos de trytond tanto estructura como datos
TRYTON_BASE_MODULE=/usr/local/lib/python3.11/dist-packages/trytond/modules
TRYTON_BASE_IR=/usr/local/lib/python3.11/dist-packages/trytond/ir
TRYTON_BASE_RES=/usr/local/lib/python3.11/dist-packages/trytond/res
# EL nombre de la base de datos demo (Instalará una base de datos demo con datos de prueba oficiales de Tryton). No se aconseja cambiar el nombre.
TRYTON_DB_DEMO=tryton_demo
# Recupera el fichero de datos demo .dump de la versión de tryton instalada en su docker para incorporarla en su base de datos (TRYTON_DB_DEMO).
# Para montar y recuperar el fichero sql es de la siguiente forma: database-(Versión de tryton dos digítos).dump, ejemplo: https://www.tryton.org/~demo/database-7.8.dump
TRYTON_DATA_DEMO=https://www.tryton.org/~demo/
# Nombre inicial del fichero dump, el programa según versión terminará de montar el nombre completo para su descarga. Ejemplo: database-7.8.dump
TRYTON_FILE_DEMO=database-
# Módulos generales a instalar (Para cambiar el orden o modificar los módulos, debe tener conocimientos de tryton, puede existir conflictos al instalar los módulos por sus dependencias entre sí)
# La instalación de los módulos se procesa por fases de 1/8 a 8/8, para dar tiempo al servidor de instalar cada módulo, y a su vez, controlar que no existan conflictos entre ellos.
TRYTON_MODULE_F1=country currency company party bank
TRYTON_MODULE_F2=product stock
TRYTON_MODULE_F3=account account_eu account_product account_invoice account_invoice_stock account_payment account_statement account_tax_rule_country
TRYTON_MODULE_F4=sale purchase
TRYTON_MODULE_F5=stock_supply purchase_request
TRYTON_MODULE_F6=product_image product_attribute product_measurements product_price_list stock_lot
TRYTON_MODULE_F7=production production_routing production_work stock_supply_production project timesheet company_work_time carrier stock_shipment_cost sale_shipment_cost incoterm
TRYTON_MODULE_F8=dashboard marketing party_relationship party_avatar
# Modulos instalados en demo por dump (solo sirve para comprobar si están activos los modulos en tryton_demo y auditar la instalación con su estructura y datos)
TRYTON_MODULE_D1=country currency company party bank
TRYTON_MODULE_D2=product stock
TRYTON_MODULE_D3=account account_payment account_product account_statement account_invoice account_invoice_stock
TRYTON_MODULE_D4=sale purchase
TRYTON_MODULE_D5=production production_work party_avatar company_work_time timesheet
TRYTON_MODULE_D6=project
# Dependiendo de la variable TRYTON_LANGUAGE, cargará de forma automatica el modulo del idioma especificado del lenguaje.
# Tryton soporta multiples idiomas, se puede instalar más idiomas de forma manual desde el menú principal de tcd.bat
TRYTON_MODULE_ES=account_es account_statement_sepa account_statement_aeb43
TRYTON_MODULE_FR=party_siret account_fr account_fr_chorus account_payment_sepa account_payment_sepa_cfonb
TRYTON_MODULE_DE=account_de_skr03 account_statement_mt940